# Port for the search server
PORT=8000

# Cache backend: sqlite | redis
CACHE_BACKEND=sqlite
REDIS_URL=redis://localhost:6379

# SearXNG instance (run your own for truly unlimited)
# docker run -d -p 8888:8080 searxng/searxng
SEARXNG_URL=http://localhost:8888

# Optional: Brave Search API key (for API mode instead of scraping)
BRAVE_API_KEY=

# Cache TTL in seconds
CACHE_TTL_SEARCH=3600
CACHE_TTL_FETCH=1800

# Max concurrent requests per backend
MAX_CONCURRENT=10
