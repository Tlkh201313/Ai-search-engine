# ============================================================================
#  AI Research Engine — backend configuration
#  Copy to `.env` and edit. Every value below has a safe default; the app runs
#  with NO changes. Answers are grounded once you point LLM_BASE_URL/LLM_API_KEY
#  at your hosted model; until then it returns deterministic extractive answers.
# ============================================================================

# --- Server ---
API_HOST=0.0.0.0
API_PORT=8000
ENVIRONMENT=development
# Comma-separated list of allowed browser origins (the web app).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Requests per minute per client IP for expensive endpoints (research/fetch).
RATE_LIMIT_PER_MINUTE=30

# --- Cache ---
# sqlite (persistent, default) | memory (ephemeral)
CACHE_BACKEND=sqlite
CACHE_DB_PATH=./data/cache.db
CACHE_TTL_SEARCH=3600
CACHE_TTL_FETCH=86400
CACHE_TTL_RESEARCH=1800

# --- Search providers ---
# Comma-separated, tried concurrently. Free / no-key: duckduckgo, wikipedia, searxng.
# Optional scrapers (flaky): brave, bing, mojeek.
SEARCH_PROVIDERS=duckduckgo,wikipedia
# Your own SearXNG instance for unlimited meta-search (optional):
#   docker run -d -p 8888:8080 searxng/searxng
SEARXNG_URL=

# --- Fetch / scrape ---
FETCH_TIMEOUT=12
FETCH_MAX_CHARS=12000
FETCH_CONCURRENCY=6
# SSRF guard: block requests to private / loopback IPs. Keep false in production.
ALLOW_PRIVATE_IPS=false

# ============================================================================
#  LLM — ONE server-hosted model behind ONE Anthropic-Messages-compatible URL.
#  The operator sets these once. End users never provide keys.
#  Leave LLM_API_KEY empty (or "dummy") to run in extractive-fallback mode.
# ============================================================================
LLM_BASE_URL=https://api.anthropic.com
LLM_API_KEY=
LLM_MODEL=claude-sonnet-5
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
LLM_ANTHROPIC_VERSION=2023-06-01
