# ============================================================================
#  AI Research Engine — backend configuration
#  Copy to `.env` and edit. Every value below has a safe default; the app runs
#  with NO changes. Answers are grounded once you point LLM_BASE_URL/LLM_API_KEY
#  at your hosted model; until then it returns deterministic extractive answers.
# ============================================================================

# --- Server ---
API_HOST=0.0.0.0
# If 8000 is taken (Docker Desktop, another local service), pick a free port and
# set NEXT_PUBLIC_API_URL in apps/web/.env.local to match. `python -m app` reads this.
API_PORT=8000
ENVIRONMENT=development
# Comma-separated list of allowed browser origins (the web app).
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
# Requests per minute per client IP for expensive endpoints (research/fetch).
RATE_LIMIT_PER_MINUTE=30

# --- Cache ---
# sqlite (persistent, default) | memory (ephemeral)
CACHE_BACKEND=sqlite
CACHE_DB_PATH=./data/cache.db
CACHE_TTL_SEARCH=3600
CACHE_TTL_FETCH=86400
CACHE_TTL_RESEARCH=1800

# --- Search providers ---
# Comma-separated, tried concurrently. Free / no-key: duckduckgo, wikipedia, searxng.
# Optional scrapers (flaky): brave, bing, mojeek.
SEARCH_PROVIDERS=duckduckgo,wikipedia
# Your own SearXNG instance for unlimited meta-search (optional):
#   docker run -d -p 8888:8080 searxng/searxng
SEARXNG_URL=

# --- Fetch / scrape ---
FETCH_TIMEOUT=10
FETCH_MAX_CHARS=12000
FETCH_CONCURRENCY=10
# SSRF guard: block requests to private / loopback IPs. Keep false in production.
ALLOW_PRIVATE_IPS=false

# ============================================================================
#  LLM — ONE hosted gateway serving several models behind ONE base URL.
#  The operator sets these once; end users never provide keys. Leave
#  LLM_API_KEY empty to run in extractive-fallback mode (a "dummy" value is
#  fine if the gateway is keyless). Personas map to specific models internally
#  (Solstice=claude-opus, Lunar=claude-4-sonnet, Tellus=kimni-k2-5,
#   Zephyr=llama-4-maverick + claude-3-haiku fusion) — see app/llm/personas.py.
# ============================================================================
LLM_BASE_URL=https://homelander.ca
LLM_API_KEY=dummy
# openai -> POST {base}/v1/chat/completions (supports tools).  anthropic -> /v1/messages
LLM_API_STYLE=openai
LLM_MAX_TOKENS=2048
LLM_TIMEOUT=60
# solstice | lunar | tellus | zephyr
DEFAULT_PERSONA=lunar
# Evidence-gathering tool rounds before the final streamed synthesis pass.
LLM_MAX_TOOL_ROUNDS=3
